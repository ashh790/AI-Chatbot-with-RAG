# Copy to .env and fill in. Never commit .env.

FLASK_APP=app.py
FLASK_DEBUG=true

# Sign Flask sessions -- generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# =====================================================================
# LLM PROVIDER -- pick ONE block below and uncomment it.
#
# The app talks the OpenAI protocol, so any compatible provider works.
# OpenAI itself has NO free tier (free credits were removed in 2024),
# so the free options below are third-party.
# =====================================================================

# --- Option 1: Groq -- free, no credit card, very fast -----------------
# Key: https://console.groq.com/keys       (keys look like gsk_...)
# Free tier: ~30 req/min, ~1000 req/day
OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# --- Option 2: Google Gemini -- free, no credit card -------------------
# Key: https://aistudio.google.com/apikey  (AIza... or newer AQ.... format)
# Note: gemini-2.5-flash is retired for new keys -- use a 3.x model.
# If a model 404s with "no longer available to new users", list what your
# key can actually reach:
#   curl -H "x-goog-api-key: $KEY" https://generativelanguage.googleapis.com/v1beta/models
# OPENAI_API_KEY=your_gemini_key_here
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL_NAME=gemini-3.1-flash-lite

# --- Option 3: OpenRouter -- free models, one key for many providers ---
# Key: https://openrouter.ai/keys          (keys look like sk-or-...)
# Free tier: ~200 req/day on models tagged ":free"
# OPENAI_API_KEY=sk-or-your_openrouter_key_here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free

# --- Option 4: OpenAI -- PAID, requires credit on the account ----------
# Key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=
# MODEL_NAME=gpt-4o-mini

# =====================================================================
# Embeddings for RAG
# =====================================================================
# Only used when OPENAI_BASE_URL is empty (i.e. real OpenAI). Every other
# provider falls back to Chroma's local embedding model automatically --
# free, offline, downloads ~80MB once. Groq has no embeddings endpoint.
EMBEDDING_MODEL=text-embedding-3-small

# --- Optional tuning ---
COLLECTION_NAME=knowledge_base
RAG_RESULTS=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_HISTORY_MESSAGES=10
MAX_TOOL_ROUNDS=5
